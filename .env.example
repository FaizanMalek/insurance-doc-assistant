# ---- Provider: "azure" (Foundry, default) or "openai" (fallback) ----
PROVIDER=azure

# ---- Microsoft Foundry (paste from the portal "Call this model" snippet) ----
# Use the FULL base_url that ends in /openai/v1
AZURE_OPENAI_ENDPOINT=https://faizan-foundry.services.ai.azure.com/openai/v1
AZURE_OPENAI_KEY=your-api-key
AZURE_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_EMBED_DEPLOYMENT=text-embedding-3-small

# ---- Azure AI Search ----
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_INDEX=policies

# ---- OpenAI fallback (only if PROVIDER=openai) ----
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Retrieval settings ----
TOP_K=5
CHUNK_WORDS=400
CHUNK_OVERLAP=60
EMBED_DIM=1536
